#!/bin/bash
# Git pre-push hook to run tests before pushing
# Install: ln -s ../../.githooks/pre-push .git/hooks/pre-push

echo "Running tests before push..."

# Activate virtual environment
if [ -d "venv" ]; then
    source venv/bin/activate
fi

# Run tests
PYTHONNOUSERSITE=1 python -m pytest --tb=short -q

if [ $? -ne 0 ]; then
    echo "❌ Tests failed! Push aborted."
    echo "Fix the tests or use 'git push --no-verify' to skip (not recommended)"
    exit 1
fi

echo "✅ All tests passed! Proceeding with push..."
exit 0
